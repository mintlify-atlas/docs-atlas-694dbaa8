  "keyFeatures": [
    "Filesystem-based job queue with atomic state transitions",
    "Three simple CLI tools: nrvnad (daemon), wrk (submit), flw (collect)",
    "Built-in llama.cpp integration with Metal/CUDA support",
    "Multi-model routing and parallel job processing",
    "Vision and embedding support with GGUF models",
    "Composable with shell scripts and Unix pipes"
  ],
  "publicApiSurface": [
    "nrvnad - Daemon server that loads models and processes jobs",
    "wrk - Submit text, vision, or embedding jobs",
    "flw - Retrieve job results and status",
    "Work::submit() - C++ API for job submission",
    "Flow::get() - C++ API for result retrieval",
    "Flow::status() - C++ API for job status",
    "Server::start() - C++ API for starting inference server"
  ]
